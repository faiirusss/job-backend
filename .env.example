APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

PG_HOST=localhost
PG_PORT=5432
PG_DB=jhai
PG_USER=jhai
PG_PASSWORD=jhai_dev_password

# DATABASE_URL host is "localhost" for running the app on the host (make dev).
# Under Docker Compose it is overridden to host "postgres" (see docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://jhai:jhai_dev_password@localhost:5432/jhai

# LLM provider: fake | gemini | qwen. `fake` (default) runs offline FakeLLM.
# (USE_FAKE_LLM=false with LLM_PROVIDER unset still resolves to gemini, for back-compat.)
LLM_PROVIDER=fake
USE_FAKE_LLM=true
# Optional comma-separated fallback chain used only when the active provider
# hits rate/quota limits. Example for production:
# LLM_PROVIDER=gemini
# LLM_FALLBACK_PROVIDERS=qwen
LLM_FALLBACK_PROVIDERS=
# Seconds a rate-limited provider is skipped before being re-probed (circuit
# breaker). Raise it if your primary's daily quota (RPD) is the usual limit.
LLM_PROVIDER_COOLDOWN_SECONDS=300

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_RPM_LIMIT=15

# Qwen over an OpenAI-compatible endpoint. Two options:
#  - OpenRouter (default base URL): key at https://openrouter.ai/keys,
#    e.g. QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
#  - Alibaba Cloud Model Studio (DashScope): set QWEN_BASE_URL to the
#    workspace compatible-mode URL, e.g. https://<ws>.<region>.maas.aliyuncs.com/compatible-mode/v1
#    with QWEN_MODEL=qwen3.6-flash and QWEN_ENABLE_THINKING=false.
# Free tiers are heavily rate-limited; expect 429 / insufficient_quota under load.
QWEN_API_KEY=
QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
QWEN_RPM_LIMIT=15
QWEN_BASE_URL=https://openrouter.ai/api/v1
# Qwen3 thinking toggle (Model Studio only). Leave blank for OpenRouter.
QWEN_ENABLE_THINKING=

EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

SCRAPER_MAX_CONCURRENT_BROWSERS=2
SCRAPER_TIMEOUT_SECONDS=45
CACHE_TTL_SECONDS=21600

# Glints service account. Glints search pages 2+ are login-gated; set these to
# let the backend log in and gather more than the anonymous 30-job page-1 cap.
# Use a DEDICATED Glints account with NO 2FA so headless login works.
# With these set, the FIRST search auto-seeds the session unattended — no manual
# step. Leave blank to scrape anonymously (page 1 only). (A manual headed seeder,
# `python -m app.scrapers.glints_login`, also exists for 2FA accounts.)
GLINTS_EMAIL=
GLINTS_PASSWORD=
GLINTS_STORAGE_STATE_PATH=./data/glints_state.json

CV_FILES_DIR=./data/cv_files
